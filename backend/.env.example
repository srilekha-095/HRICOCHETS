# Server Configuration
PORT=8080
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Local development
PG_HOST=localhost
PG_USER=postgres
PG_PASSWORD=password
PG_DATABASE=db_name
PG_PORT=5432

# OR use connection string (for Railway, Supabase, etc.)
# For Supabase, get this from: Settings → Database → Connection String (Pooler Mode)
DATABASE_URL=postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ========== SUPABASE CONFIGURATION (Optional) ==========
# Only needed if using Supabase REST API from backend
SUPABASE_URL=your-public-api-url-here
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# JWT Secret (Change this to a random string in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@yoursite.com

# Owner Notifications (comma-separated)
OWNER_EMAILS=owner@yoursite.com
OWNER_NAME=Shop Owner
SHOP_NAME=Minimalist Shop

# CORS Settings (Frontend URL)
FRONTEND_URL=http://localhost:5173

# Optional: Payment Integration (for future)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
